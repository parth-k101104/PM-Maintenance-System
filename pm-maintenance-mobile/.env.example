# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real IPs or secrets.

# Base URL of the Spring Boot backend (no trailing slash).
# Examples:
#   Local emulator  : http://10.0.2.2:8080
#   LAN device      : http://192.168.1.x:8080
#   Tunnel / ngrok  : https://xxxx.ngrok.io
EXPO_PUBLIC_API_BASE_URL=http://CHANGE_ME:8080
