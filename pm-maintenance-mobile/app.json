{
  "expo": {
    "name": "PM Maintenance Mobile",
    "slug": "pm-maintenance-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.maint.pm.mobile"
    },
    "ios": {
      "bundleIdentifier": "com.maint.pm.mobile"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PM Maintenance Mobile to scan equipment QR codes."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:8080"
    }
  }
}
