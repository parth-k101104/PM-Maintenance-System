ANALYTICS_API_KEY=local-dev-static-key
ANALYTICS_SHARED_SECRET=change-me-to-a-long-random-shared-secret-used-by-main-backend
ANALYTICS_TOKEN_CLOCK_SKEW_SECONDS=60
# Local host access to pm-backend/docker-compose.yml Postgres.
DATABASE_URL=postgresql://postgres:root@localhost:5433/pm_db
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=8
WARN_THRESHOLD_RATIO=0.875
STABLE_SLOPE_EPSILON=0.002
ANOMALY_VELOCITY_RATIO=1.3
